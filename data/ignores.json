{
  "common": {
    "description": "Common ignore rules shared across all AI assistants",
    "rules": [
      "# Common AI assistant ignores",
      "node_modules/",
      ".git/",
      ".env",
      ".env.local",
      "*.log",
      "dist/",
      "build/",
      ".DS_Store",
      "",
      "# IDE files",
      ".vscode/",
      ".idea/",
      "*.sublime-*",
      "",
      "# Large files and binaries",
      "*.zip",
      "*.tar.gz",
      "*.rar",
      "*.exe",
      "*.dll",
      "*.so",
      "*.dylib",
      "*.pdf",
      "*.mp4",
      "*.mp3",
      "*.mov",
      "*.avi",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "",
      "# Dependencies and packages",
      "vendor/",
      "bower_components/",
      "*.min.js",
      "*.min.css",
      "",
      "# Build artifacts",
      "coverage/",
      ".next/",
      "out/",
      ".nuxt/",
      ".cache/",
      "",
      "# Database files",
      "*.sqlite",
      "*.db",
      "*.sql",
      "",
      "# Temporary files",
      "tmp/",
      "temp/",
      "*.tmp",
      "*.cache",
      "*.swp",
      "*.swo"
    ]
  },
  "agents": [
    {
      "id": "claude",
      "name": "Claude",
      "description": "Anthropic's Claude AI assistant",
      "website": "https://claude.ai",
      "ignoreFileName": ".claudeignore",
      "specificIgnore": [
        "# Claude specific ignores",
        ".claude/",
        ".claude_history",
        "claude_cache/"
      ]
    },
    {
      "id": "cursor",
      "name": "Cursor",
      "description": "Cursor AI code editor",
      "website": "https://cursor.sh",
      "ignoreFileName": ".cursorignore",
      "specificIgnore": [
        "# Cursor specific ignores",
        ".cursor/",
        ".cursorignore"
      ]
    },
    {
